# Mariner Nexus — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ─────────────────────────────────────────
# GoHighLevel CRM Integration
# ─────────────────────────────────────────
# Webhook URL from your GoHighLevel account
# Path: Settings → Integrations → Webhooks → Create Webhook
GHL_WEBHOOK_URL=

# ─────────────────────────────────────────
# Cal.com Booking Integration
# ─────────────────────────────────────────
# Your Cal.com username and event slug
# Used in: components/integrations/CalEmbed.tsx
NEXT_PUBLIC_CAL_USERNAME=
NEXT_PUBLIC_CAL_EVENT_SLUG=strategy-call

# ─────────────────────────────────────────
# Site URL (for OG images, canonical URLs)
# ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://marinernexus.com
